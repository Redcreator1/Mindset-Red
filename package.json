{
  "name": "mindset-ctx",
  "version": "0.5.0",
  "description": "Context-as-a-Service: generate and maintain AI-ready context (CLAUDE.md, AGENTS.md, architecture docs, prompt templates) for any GitHub repo, with a memory layer over its history.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ctx": "dist/cli.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test dist/test/*.test.js",
    "dev": "tsc --watch",
    "ctx": "npm run build && node dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Redcreator1/Mindset-Red.git"
  },
  "keywords": [
    "ai",
    "context",
    "claude",
    "agents",
    "developer-tools",
    "documentation"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0"
  }
}
