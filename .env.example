# mindset-ctx — example runtime configuration.
# Copy to .env and fill in for local dev; on Fly use `fly secrets set` instead.

# --- Public host (used in Stripe redirect URLs, App manifest) ---
CTX_BASE_URL=https://mindset-ctx.example.com

# --- Tenant store (file-backed, persists Stripe plan changes) ---
CTX_TENANTS=./ctx.tenants.json

# --- Stripe (payments) ---
# Secret key for creating Checkout Sessions (sk_test_... in test mode).
CTX_STRIPE_API_KEY=sk_test_...
# Webhook signing secret (from Stripe → Developers → Webhooks).
CTX_STRIPE_SECRET=whsec_...
# Price ID → plan map. Get IDs from `ctx stripe bootstrap`.
STRIPE_PRICE_MAP={"price_...":"pro","price_...":"team"}

# --- GitHub webhooks + App ---
CTX_WEBHOOK_SECRET=change-me-random-hex
